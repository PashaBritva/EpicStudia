{
  "name": "epicstudia",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000 --host",
    "dev:all": "concurrently --kill-others-on-fail \"npm run dev\" \"npm run api\"",
    "api": "cd ../EpicStudiaApi && node bin/www",
    "api:install": "cd ../EpicStudiaApi && npm install",
    "install:all": "npm install && npm run api:install",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview --port 3000 --host",
    "prepare": "husky",
    "test": "echo \"Tests coming soon\""
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.2",
    "@mui/material": "^6.4.1",
    "axios": "^1.7.9",
    "hls.js": "^1.5.20",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^2.16.0",
    "react-router-dom": "^7.1.3",
    "video.js": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vite": "^6.0.5"
  }
}
